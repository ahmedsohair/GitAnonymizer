PORT=5000

# GitHub OAuth app credentials (required for login and private repositories)
CLIENT_ID=
CLIENT_SECRET=
GITHUB_TOKEN=

# Session and app settings
SESSION_SECRET=change_me
APP_BASE_URL=http://localhost:5000
AUTH_CALLBACK=http://localhost:5000/github/auth
APP_HOSTNAME=localhost
TRUST_PROXY=1

# Railway auto-populates this. If set and APP_BASE_URL is empty, callback/host are inferred.
RAILWAY_PUBLIC_DOMAIN=

# Internal services (used by docker-compose advanced profile)
REDIS_HOSTNAME=advanced-redis
REDIS_PORT=6379
REDIS_URL=
DB_HOSTNAME=advanced-mongodb
DB_USERNAME=admin
DB_PASSWORD=password
MONGODB_URI=
STREAMER_ENTRYPOINT=http://advanced-streamer:5000/

# Optional behavior
ENABLE_DOWNLOAD=true
ANONYMIZATION_MASK=XXXX
