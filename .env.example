# Core runtime defaults
DATABASE_URL=postgresql+psycopg2://mirrors:mirrors@postgres:5432/mirrors
REDIS_URL=redis://redis:6379/0
MIRROR_STORAGE_ROOT=/data/mirrors
TEMP_ROOT=/data/tmp
DEFAULT_URL_TTL_DAYS=90

# Advanced runtime GitHub OAuth (platform-managed login)
ADVANCED_GITHUB_CLIENT_ID=
ADVANCED_GITHUB_CLIENT_SECRET=

# Advanced runtime public URL
# On Railway, you can keep these empty and rely on RAILWAY_PUBLIC_DOMAIN auto-detection.
ADVANCED_APP_BASE_URL=
ADVANCED_AUTH_CALLBACK=
ADVANCED_APP_HOSTNAME=
ADVANCED_TRUST_PROXY=1
